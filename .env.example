# Copy this file to .env and fill in the values from your Firebase project's
# Project Settings > Your apps > SDK setup and configuration.
# .env itself is gitignored — never commit your actual values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Your own Firebase Auth UID, once you've created the admin (email+password)
# account for rulebook editing — Firebase Console > Authentication > Users,
# after signing in once. Leave blank and owner access just stays off
# (fails safe, not open).
VITE_OWNER_UID=
