# Copy this file to .env and fill in the values from your Firebase project's
# Project Settings > Your apps > SDK setup and configuration.
# .env itself is gitignored — never commit your actual values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Your own Firebase Auth UID, once you've created the admin (email+password)
# account for rulebook editing — Firebase Console > Authentication > Users,
# after signing in once. Leave blank and owner access just stays off
# (fails safe, not open).
VITE_OWNER_UID=

# --- Server-side only, below this line ---
# These are read by netlify/functions/save-rulebook.js at runtime, NEVER by
# the browser — no VITE_ prefix, since that prefix is specifically what
# tells Vite "expose this to client code." `netlify dev` reads these from
# this same .env file for local testing; in production they live ONLY in
# Netlify's dashboard (Site configuration > Environment variables), never
# committed anywhere.

# The exact same UID as VITE_OWNER_UID above — this is the one that
# actually matters for security (the client-side copy is just UI gating).
OWNER_UID=

# A GitHub Personal Access Token (fine-grained, scoped to just this repo,
# Contents: Read and write) — Settings > Developer settings > Personal
# access tokens on GitHub.
GITHUB_TOKEN=

# From your Firebase service account key (Project Settings > Service
# Accounts > Generate new private key — downloads a JSON file). Copy the
# matching fields from that JSON into these three:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
