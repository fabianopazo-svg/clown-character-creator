rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomCode} {
      // Any signed-in user (anonymous auth counts) can read a room they know the code for.
      allow read: if request.auth != null;

      // Only the room's creator can write themself in as MC — prevents someone else
      // creating a room and claiming MC on a code they didn't generate.
      allow create: if request.auth != null
                    && request.resource.data.mcUid == request.auth.uid;

      // Room-level updates: the MC can change anything (Spotlight, House Die
      // result, House Difficulty, etc.). Any other authenticated participant
      // can ALSO write to this doc, but only if the write touches nothing
      // besides momentum and/or suspicion — that's what lets a player's own
      // dice roll grant party Momentum on a Critical Success, or bump
      // Suspicion on a Complication/Corpsing, without needing MC-only access
      // to the whole document.
      allow update: if request.auth != null
                    && (resource.data.mcUid == request.auth.uid
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['momentum', 'suspicion']));

      // Only the MC can delete their own room outright — used for the MC
      // Corner's full room-deletion flow, which cascades through every
      // subcollection below before finally removing this doc.
      allow delete: if request.auth != null && resource.data.mcUid == request.auth.uid;

      match /rolls/{rollId} {
        // Anyone in the room can see the roll log.
        allow read: if request.auth != null;
        // Anyone can log a roll, but only as themself — rollerUid must match
        // the caller, so nobody can post a roll pretending to be someone
        // else. One exception: the MC can post a roll with rollerUid ==
        // null, used for NPC/freeform rolls via the MC Dice Roller — these
        // aren't attributed to any player's own account at all.
        allow create: if request.auth != null
                      && (
                        request.resource.data.rollerUid == request.auth.uid
                        || (
                          request.resource.data.rollerUid == null
                          && get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid
                        )
                      );
        // Rolls are otherwise an honest historical log — no edits, except
        // three narrow cases, all one-directional: the MC recording a
        // Flop-award decision (only flopAwarded, only on outcome 'flop');
        // the roller setting revealingAt (the broadcast signal that starts
        // the drumroll sound playing for everyone, before the result is
        // actually shown); and the roller flipping `revealed` to true
        // (which happens only after their own drumroll audio finishes —
        // see RollPanel). Nothing else about a logged roll can ever change.
        allow update: if request.auth != null
                      && (
                        (get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid
                         && resource.data.outcome == 'flop'
                         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flopAwarded']))
                        || (request.auth.uid == resource.data.rollerUid
                            && resource.data.revealed == false
                            && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revealed'])
                                || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revealingAt'])))
                      );
        // Rolls can also be deleted, but ONLY by this room's MC — used for
        // the MC Corner's full room-deletion flow. This does technically
        // let the MC delete an individual roll at any time too, not just
        // during a full wipe; that's an accepted trade-off given the MC
        // already has full narrative authority over the game.
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid;

        match /reactions/{reactorUid} {
          // Anyone in the room can see who reacted with what.
          allow read: if request.auth != null;
          // A player can set/change/remove their OWN reaction. The MC can
          // ALSO delete any reaction — needed for cascading room deletion.
          allow write: if request.auth != null
                       && (request.auth.uid == reactorUid
                           || get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid);
        }
      }

      match /giftIntents/{intentId} {
        // "I want to use [Gift]" flags — any player can post their own,
        // visible to everyone (especially the MC, who responds with a
        // targeted prompt). Immutable once posted.
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.playerUid == request.auth.uid;
        allow update, delete: if false;
      }

      match /suspicionSpends/{spendId} {
        // Visible to the whole table — the tension of Suspicion moving
        // should be a shared, dramatic beat, not a private MC bookkeeping
        // line. Only the MC can create one, and only tagged as themself.
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.spentByUid == request.auth.uid
                      && get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid;
        allow update, delete: if false;
      }

      match /mcNpcs/{npcId} {
        // Same MC-only boundary as mcPrivate — live NPC/monster trackers
        // for the current session, never visible to players.
        allow read, write: if request.auth != null
                            && get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid;
      }

      match /mcPrivate/{docId} {
        // Truly MC-only — unlike private/sheet below (owner + MC), nobody
        // but the MC ever reads or writes this, not even the players it
        // might be about. This is the foundation the rest of the Hidden MC
        // Screen (NPC trackers, Suspicion-spend log) will build on.
        allow read, write: if request.auth != null
                            && get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid;
      }

      match /prompts/{promptId} {
        // Anyone in the room can see a posted roll prompt.
        allow read: if request.auth != null;
        // Only this room's actual MC can post one, and only tagged as themself.
        allow create: if request.auth != null
                      && request.resource.data.postedByUid == request.auth.uid
                      && get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid;
        // Prompts can't be edited, but the MC can delete one — needed for
        // cascading room deletion, not for retroactively hiding a prompt
        // mid-session (nothing stops that misuse either, same trust
        // trade-off as rolls above).
        allow update: if false;
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid;
      }

      match /players/{playerId} {
        // Roster doc: identity/summary only (no resources) — safe for anyone in the room to read.
        allow read: if request.auth != null;
        // A player can only write to their own roster entry. The MC can
        // ALSO delete (but not otherwise write) any player's roster entry
        // — needed for cascading room deletion.
        allow write: if request.auth != null
                     && (request.auth.uid == playerId
                         || (request.resource == null
                             && get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid));

        match /private/{docId} {
          // Full character + live resources. Only the player themself, or this
          // room's MC, can read it — everyone else in the room is blocked even
          // though they can see the roster doc one level up.
          allow read: if request.auth != null
                      && (request.auth.uid == playerId
                          || get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid);
          // The player can write anything on their own sheet. The MC can
          // ALSO write to it, but only to grant a Flop's Laughter award —
          // the write must touch nothing but character.play.laughter (plus
          // the updatedAt timestamp). This is checked at every level: the
          // top-level diff must be exactly {character, updatedAt}, the
          // diff within character must be exactly {play}, and the diff
          // within character.play must be exactly {laughter}. The MC can
          // never touch gifts, attributes, other resources, or anything
          // else on a player's sheet through this path. A second MC
          // exception allows a full delete (request.resource == null) —
          // used only by cascading room deletion in the MC Corner. A third
          // exception lets ANY room member adjust specific resource fields
          // on another player's sheet — used for Gift effects that target
          // an ally (e.g. Physician's First Aid healing someone else's
          // Face). Scoped to a fixed allowlist of fields, not an amount —
          // the actual amount is a client-side concern driven by which
          // specific Gift is being used, not something these rules can
          // know about. The client always writes via increment(), which
          // Firestore resolves to a real number before rules evaluate it,
          // so this same diff-based check works identically either way.
          allow write: if request.auth != null
                       && (
                         request.auth.uid == playerId
                         || (
                           get(/databases/$(database)/documents/rooms/$(roomCode)).data.mcUid == request.auth.uid
                           && (
                             // The Flop-award exception: touches only character.play.laughter.
                             (request.resource != null
                              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['character', 'updatedAt'])
                              && request.resource.data.character.diff(resource.data.character).affectedKeys().hasOnly(['play'])
                              && request.resource.data.character.play.diff(resource.data.character.play).affectedKeys().hasOnly(['laughter']))
                             // Or a full delete, for cascading room deletion.
                             || request.resource == null
                           )
                         )
                         || (
                           // Any room member: Gift-effect resource adjustments on an ally.
                           request.resource != null
                           && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['character', 'updatedAt'])
                           && request.resource.data.character.diff(resource.data.character).affectedKeys().hasOnly(['play'])
                           && request.resource.data.character.play.diff(resource.data.character.play).affectedKeys().hasOnly(['face', 'laughter', 'pathResource'])
                           && request.resource.data.character.play.pathResource.diff(resource.data.character.play.pathResource).affectedKeys().hasOnly(['comfort', 'debt', 'conviction', 'cardsInHand'])
                         )
                       );
        }
      }
    }
  }
}
